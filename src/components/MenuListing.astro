---
// src/components/MenuListing.astro
// Plain <img> tags — no Astro Image component, no import errors.
// Put product photos in: public/products/

import { CATEGORIES, PACKAGES } from "../data/menu.ts";
---

<section class="section-menu" id="menu">

  <!-- Dark hero -->
  <div class="menu-hero">
    <div class="container text-center">
      <h2 class="heading-secondary text-white">What's Your Flavour?</h2>
      <p class="text-white/60 text-base max-w-xl mx-auto -mt-6">
        All juices sold in sets of 20 bottles. Freshly made. Zero additives.
      </p>
    </div>
  </div>

  <!-- Pricing cards -->
  <div class="pricing-wrap">
    <div class="container">
      <div class="pricing-grid">
        {PACKAGES.map((pkg) => (
          <div class={`pricing-card ${pkg.featured ? "pricing-card--featured" : ""}`}>
            {pkg.badge && <span class="pricing-badge">{pkg.badge}</span>}
            <div class="pricing-img-wrap">
              <img src={pkg.image} alt={pkg.label} class="pricing-img" loading="lazy" />
            </div>
            <div class="pricing-body">
              <p class="pricing-size">{pkg.size}</p>
              <p class="pricing-label">{pkg.label}</p>
              <p class="pricing-desc">{pkg.description}</p>
              <p class="pricing-price">GHS {pkg.price}</p>
              <a href="/order" class="btn btn-yellow mt-4 inline-block">Order Now</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Category tabs -->
  <div class="container py-20">
    <div class="menu-tabs" id="menuTabs" role="tablist">
      <button class="menu-tab active" data-category="all" role="tab">All</button>
      {CATEGORIES.map((cat) => (
        <button class="menu-tab" data-category={cat.id} role="tab">{cat.name}</button>
      ))}
    </div>
  </div>

  <!-- Flavour grid -->
  <div class="container py-16">
    <div class="flavour-grid" id="flavourGrid">
      {CATEGORIES.map((cat) => (
        <div class="flavour-card" data-category={cat.id}>
          <div class="flavour-card-img-wrap">
            <img src={cat.image} alt={cat.name} class="flavour-card-img" loading="lazy" />
            <div class="flavour-card-overlay">
              <h3 class="flavour-card-name">{cat.name}</h3>
              <span class="flavour-card-count">{cat.flavours.length} blends</span>
            </div>
          </div>
          <ul class="flavour-list">
            {cat.flavours.map((f) => (
              <li class="flavour-item">
                <span>{f.name}</span>
                <span class="flex gap-1">
                  {f.seasonal && <span class="ftag ftag--s">Seasonal</span>}
                  {f.custom   && <span class="ftag ftag--c">+GHS</span>}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Custom card -->
      <div class="flavour-card flavour-card--custom" data-category="custom">
        <div class="custom-inner">
          <span class="text-4xl mb-4 block">✦</span>
          <h3 class="text-xl font-bold text-white mb-3">Your Custom Blend</h3>
          <p class="text-white/60 text-sm leading-relaxed mb-6">
            Tell us exactly what you want — we'll make it fresh for you.
          </p>
          <a href="/order" class="btn btn-yellow">Build Your Blend →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Notes strip -->
  <div class="notes-strip">
    <div class="container">
      <div class="notes-inner">
        <span>Pay by <strong>Friday</strong> — delivered from <strong>Wednesday</strong></span>
        <span class="notes-dot">·</span>
        <span><strong>Custom blends</strong> carry an additional charge</span>
        <span class="notes-dot">·</span>
        <span>Up to <strong>1,000 bottles</strong> — 2-week lead time, DM us</span>
      </div>
    </div>
  </div>

</section>








<script>
  const tabs  = document.querySelectorAll<HTMLButtonElement>(".menu-tab");
  const cards = document.querySelectorAll<HTMLElement>(".flavour-card");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const sel = tab.dataset.category ?? "all";
      tabs.forEach((t) => { t.classList.remove("active"); t.setAttribute("aria-selected", "false"); });
      tab.classList.add("active");
      tab.setAttribute("aria-selected", "true");
      cards.forEach((c) => {
        c.style.display = (sel === "all" || c.dataset.category === sel) ? "" : "none";
      });
    });
  });
</script>














<style lang="scss">
  .section-menu { background-color: var(--clr-gray-light); }


//   Menu Hero
  .menu-hero {
    background-image: linear-gradient(to right, var(--clr-gray-light), var(--clr-dark));
    padding: 10rem 0 6rem;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 3rem), 0 100%);
  }

  .pricing-wrap {
        padding: 10rem 0 5rem;
        background-color: var(--clr-white);
        margin-top: -4rem;
    }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    @media (max-width: 768px) { grid-template-columns: 1fr; }
  }

  .pricing-card {
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid #eee;
    background: var(--clr-white);
    transition: transform 0.25s, box-shadow 0.25s;
    position: relative;
    &:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.1); }
    &--featured { border-color: var(--clr-yellow); box-shadow: 0 4px 24px rgba(254,218,28,0.25); }
  }

  .pricing-badge {
    position: absolute; top: 0.75rem; right: 0.75rem; z-index: 2;
    font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
    background: var(--clr-yellow); color: var(--clr-black);
    padding: 0.25rem 0.65rem; border-radius: 1rem; font-weight: 700;
  }

  .pricing-img-wrap {
    height: 200px; overflow: hidden;
    img { width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: transform 0.4s; }
  }
  .pricing-card:hover .pricing-img-wrap img { transform: scale(1.05); }

  .pricing-body { padding: 1.5rem; }
  .pricing-size  { font-family: "Century Gothic", sans-serif; font-size: 1.8rem; font-weight: 700; color: var(--clr-dark); line-height: 1; margin-bottom: 0.25rem; }
  .pricing-label { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-bottom: 0.3rem; }
  .pricing-desc  { font-size: 0.85rem; color: #777; margin-bottom: 0.75rem; }
  .pricing-price { font-size: 1.2rem; font-weight: 700; color: var(--color-green); }

  .menu-tabs {
     display: flex;
     gap: 0.5rem;
     flex-wrap: wrap;
     padding: 3rem 0;;
     }

  .menu-tab {
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.55rem 1.1rem; background: var(--clr-white); border: 2px solid #e0e0e0;
    color: #666; cursor: pointer; font-family: inherit; border-radius: 2rem;
    transition: all 0.2s; font-weight: 700;
    &:hover { border-color: var(--clr-dark); color: var(--clr-dark); }
    &.active { background: var(--clr-dark); border-color: var(--clr-dark); color: var(--clr-white); }
  }

  .flavour-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    @media (max-width: 900px) { grid-template-columns: repeat(2, 1fr); }
    @media (max-width: 600px) { grid-template-columns: 1fr; }
    padding-bottom: 4rem;
  }

  .flavour-card {
    background: var(--clr-white); border-radius: 1rem; overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06); transition: transform 0.2s, box-shadow 0.2s;
    &:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
    &--custom { background: var(--clr-dark); display: flex; align-items: center; justify-content: center; min-height: 300px; }
  }

  .flavour-card-img-wrap {
    position: relative; height: 160px; overflow: hidden;
    img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; transition: transform 0.4s; }
  }
  .flavour-card:hover .flavour-card-img-wrap img { transform: scale(1.06); }

  .flavour-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 60%);
    display: flex; flex-direction: column; justify-content: flex-end; padding: 1rem 1.1rem;
  }
  .flavour-card-name  { font-family: "Century Gothic", sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--clr-white); line-height: 1; margin-bottom: 0.2rem; }
  .flavour-card-count { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.7); }

  .flavour-list { list-style: none; padding: 0.75rem 1rem; margin: 0; display: flex; flex-direction: column; }
  .flavour-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0; font-size: 0.8rem; color: #333;
    &:last-child { border-bottom: none; }
  }

  .ftag { font-size: 0.55rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.15rem 0.5rem; border-radius: 1rem; font-weight: 700; }
  .ftag--s { background: #f0f0f0; color: #888; }
  .ftag--c { background: rgba(254,218,28,0.15); color: #7a5500; border: 1px solid rgba(254,218,28,0.4); }

  .custom-inner { text-align: center; padding: 2.5rem 1.5rem; }

  
  
  .notes-strip {
      background: var(--clr-dark);
      padding: 5rem 0;
     }
  .notes-inner {
    display: flex; align-items: center; justify-content: center;
    gap: 1rem; flex-wrap: wrap; font-size: 0.8rem; color: rgba(255,255,255,0.55);
    strong { color: var(--clr-yellow); }
    @media (max-width: 600px) { flex-direction: column; gap: 0.4rem; text-align: center; }
  }
  .notes-dot { color: rgba(255,255,255,0.2); }
</style>